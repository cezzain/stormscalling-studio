# Storm's Calling Studio — environment
# Copy this file to `.env` and fill in a key for the AI provider you want.
# Keys are read ONLY by the backend and are never exposed to the browser.
# You only need a key for the provider you select in Settings → AI.

# Claude (Anthropic) — the default provider
ANTHROPIC_API_KEY=sk-ant-...

# ChatGPT (OpenAI) — optional
# OPENAI_API_KEY=sk-...

# Gemini (Google) — optional (GOOGLE_API_KEY also works)
# GEMINI_API_KEY=...

# ---- Login (single-user) ----
# Set BOTH of these to put the whole app behind a username + password — this is
# what makes a public deployment "only for you". Leave them unset locally and
# the app stays open (no login wall), exactly as before.
# AUTH_USERNAME=you
# AUTH_PASSWORD=a-long-strong-password
# SESSION_SECRET=  # a random string used to sign the session cookie.
#                  # Generate one with:  openssl rand -hex 32
#                  # (optional — if blank, it's derived from your credentials)

# Optional overrides (sensible defaults are in server/src/config.ts)
# AI_PROVIDER=anthropic   # anthropic | openai | google (also switchable in Settings)
# CLAUDE_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
# CLIENT_PORT=3000        # the app URL you open in the browser (dev)
# SERVER_PORT=5174        # backend API port in dev (kept behind the frontend)
# PORT=8080               # single-port production bind (cloud hosts set this for you)
# HOST=0.0.0.0
